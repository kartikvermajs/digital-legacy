# Connection string for Neon Database or any compatible PostgreSQL DB
DATABASE_URL=

# Secret used to sign JWT tokens
JWT_SECRET=

# Required for SDXL image generation (Avatar)
REPLICATE_API_TOKEN=

# Required for accessing Llama-3 (AI Engine)
